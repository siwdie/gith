{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gith Config",
  "description": "Configuration file for gith CLI",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "defaultBranch": {
      "type": "string",
      "description": "Default base branch for new branches",
      "default": "main",
      "examples": ["main", "master", "develop"]
    },
    "branchTypes": {
      "type": "array",
      "description": "Available branch types for the branch creation command",
      "items": {
        "$ref": "#/definitions/selectOption"
      }
    },
    "commitTypes": {
      "type": "array",
      "description": "Available commit types for the commit command",
      "items": {
        "$ref": "#/definitions/selectOption"
      }
    },
    "scope": {
      "description": "Scope prompt configuration for non-monorepo projects. When omitted, scope is disabled",
      "oneOf": [
        {
          "type": "object",
          "description": "Free text scope input",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["text"]
            },
            "placeholder": {
              "type": "string",
              "description": "Placeholder text shown in the input",
              "default": "branch"
            },
            "required": {
              "type": "boolean",
              "description": "Whether scope is required",
              "default": false
            }
          }
        },
        {
          "type": "object",
          "description": "Select scope from a list of options",
          "additionalProperties": false,
          "required": ["type", "options"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["select"]
            },
            "options": {
              "type": "array",
              "description": "List of scope options",
              "items": {
                "$ref": "#/definitions/selectOption"
              }
            },
            "required": {
              "type": "boolean",
              "description": "Whether scope is required",
              "default": false
            }
          }
        }
      ]
    },
    "commit": {
      "type": "object",
      "description": "Configuration for the commit command",
      "additionalProperties": false,
      "properties": {
        "header": {
          "type": "object",
          "description": "Constraints for the commit header (type + scope + description)",
          "additionalProperties": false,
          "properties": {
            "minLength": {
              "type": "integer",
              "minimum": 1,
              "description": "Minimum character length for the short description",
              "default": 10
            },
            "maxLength": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum character length for the short description",
              "default": 72
            }
          }
        },
        "body": {
          "description": "Configuration for the commit body prompt",
          "oneOf": [
            {
              "type": "boolean",
              "description": "Enable or disable the commit body prompt"
            },
            {
              "type": "object",
              "description": "Enable and configure the commit body prompt",
              "additionalProperties": false,
              "properties": {
                "required": {
                  "type": "boolean",
                  "description": "Whether to prompt for a commit body",
                  "default": false
                },
                "maxLength": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Maximum character length for the commit body",
                  "default": 200
                }
              }
            }
          ]
        }
      }
    },
    "release": {
      "type": "object",
      "description": "Configuration for release hooks",
      "additionalProperties": false,
      "properties": {
        "hooks": {
          "type": "object",
          "description": "Shell commands executed during the release flow",
          "additionalProperties": false,
          "properties": {
            "beforeCommit": {
              "type": "string",
              "description": "Shell command to run before creating the release commit. Supports placeholders like {{version}}, {{tag}}, {{scope}}, and {{branch}}"
            }
          }
        }
      }
    },
    "monorepo": {
      "type": "object",
      "description": "Monorepo settings. When defined, gith will automatically detect workspace packages and enforce single-scope commits",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Package manager or build tool used to manage the monorepo workspaces",
          "enum": ["pnpm", "yarn", "cargo", "maven", "gradle"]
        }
      }
    }
  },
  "definitions": {
    "selectOption": {
      "type": "object",
      "description": "An option shown in select prompts",
      "additionalProperties": false,
      "required": ["value"],
      "properties": {
        "value": {
          "type": "string",
          "description": "Internal value used by the CLI"
        },
        "label": {
          "type": "string",
          "description": "Text displayed in the prompt"
        },
        "hint": {
          "type": "string",
          "description": "Hint text shown alongside the option"
        }
      }
    }
  }
}