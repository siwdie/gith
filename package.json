{
  "name": "@siwdie/gith",
  "version": "1.8.0",
  "description": "Configurable git workflow CLI with branch creation, rebase, commit, and squash helpers",
  "author": {
    "name": "siwdie"
  },
  "license": "MIT",
  "repository": "https://github.com/siwdie/gith",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.6.0",
  "type": "module",
  "bin": {
    "gith": "./dist/cli.cjs"
  },
  "exports": {
    "./schema": "./schema/gith.schema.json"
  },
  "files": [
    "dist",
    "schema"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "rm -rf dist && tsup",
    "build:binaries": "npx @yao-pkg/pkg dist/cli.cjs --targets node24-linux-x64,node24-macos-arm64,node24-win-x64 --output binaries/gith-v$(node -p \"require('./package.json').version\") --fallback-to-source",
    "build:all": "pnpm build && pnpm build:binaries",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "tsc --noEmit",
    "prepare": "pnpm build",
    "generate:brew": "node scripts/brew.mjs"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24.13.1",
    "@yao-pkg/pkg": "^6.20.0",
    "eslint": "^10.4.1",
    "eslint-plugin-import-newlines": "^2.0.0",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.6.0",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}