{
  "name": "gith",
  "version": "0.1.0",
  "description": "Configurable git workflow cli with branch creation, rebase and squash helpers",
  "license": "MIT",
  "packageManager": "pnpm@11.5.1",
  "type": "module",
  "bin": {
    "gith": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.13.1"
  },
  "scripts": {
    "build": "rm -rf dist && tsup",
    "dev": "pnpm build && node --enable-source-maps ./dist/cli.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "tsc --noEmit",
    "prepare": "pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24.13.1",
    "eslint": "^10.4.1",
    "eslint-plugin-import-newlines": "^2.0.0",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.6.0",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}